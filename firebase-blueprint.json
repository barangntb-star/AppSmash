{
  "entities": {
    "SheetsConfig": {
      "title": "SheetsConfig",
      "description": "Configuration for Google Sheets linkage",
      "type": "object",
      "properties": {
        "spreadsheetId": { "type": "string" },
        "ownerUserId": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["spreadsheetId"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "General settings for banking, admin phone, and QRIS barcode",
      "type": "object",
      "properties": {
        "accountNumber": { "type": "string" },
        "bankName": { "type": "string" },
        "adminPhone": { "type": "string" },
        "qrisDataUrl": { "type": "string" }
      },
      "required": ["accountNumber", "bankName", "adminPhone"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Court booking record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courtId": { "type": "string" },
        "courtName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "bookingDate": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "totalPrice": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["Menunggu Pembayaran", "Lunas"] },
        "createdAt": { "type": "string" },
        "synced": { "type": "boolean" }
      },
      "required": ["id", "courtId", "customerName", "bookingDate", "startTime", "endTime", "totalPrice"]
    },
    "FinancialTransaction": {
      "title": "FinancialTransaction",
      "description": "A financial transaction for court cashflow",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["Masuk", "Keluar"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" },
        "synced": { "type": "boolean" }
      },
      "required": ["id", "date", "type", "amount", "category"]
    },
    "Member": {
      "title": "Member",
      "description": "Premium court member details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "phone", "address"]
    }
  },
  "firestore": {
    "configs/sheets": {
      "schema": "SheetsConfig",
      "description": "Google Sheets linking configuration"
    },
    "configs/settings": {
      "schema": "AppSettings",
      "description": "General application settings"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Bookings collection"
    },
    "transactions/{transactionId}": {
      "schema": "FinancialTransaction",
      "description": "Financial Transactions collection"
    },
    "members/{memberId}": {
      "schema": "Member",
      "description": "Registered court members list"
    }
  }
}
